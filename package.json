{
  "name": "dbstudio",
  "version": "1.0.0",
  "description": "Simple local database IDE for PostgreSQL and MongoDB",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@monaco-editor/react": "^4.6.0",
    "adm-zip": "^0.5.17",
    "electron-store": "^7.0.3",
    "mongodb": "^6.0.0",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "build": {
    "appId": "com.dbstudio.app",
    "productName": "DBStudio",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64"] },
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "artifactName": "DBStudio-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "DBStudio-${version}-windows-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Chris-garibay",
      "repo": "terrelldb"
    }
  }
}
